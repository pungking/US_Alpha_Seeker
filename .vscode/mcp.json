{
  "servers": {
    "makenotion/notion-mcp-server": {
      "type": "http",
      "url": "https://mcp.notion.com/sse",
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    },
    "google-drive": {
      "command": "npx",
      "args": [
        "@piotr-agier/google-drive-mcp"
      ],
      "env": {
        "GOOGLE_DRIVE_CLIENT_ID": "${GDRIVE_CLIENT_ID}",
        "GOOGLE_DRIVE_CLIENT_SECRET": "${GDRIVE_CLIENT_SECRET}",
        "GOOGLE_DRIVE_REFRESH_TOKEN": "${GDRIVE_REFRESH_TOKEN}"
      }
    },
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://api.githubcopilot.com/mcp/"
      ],
      "env": {
        "GITHUB_TOKEN": "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"
      }
    },
    "vercel-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.vercel.com"
      ],
      "env": {
        "VERCEL_TOKEN": "vcp_0MxsWGXXsleCeYa31dKXQY3NrOXGL48KmYAojCJInqyzKEc8cz29V5ul"
      }
    },
    "telegram-mcp": {
