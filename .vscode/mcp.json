{
  "servers": {
    "makenotion/notion-mcp-server": {
      "type": "http",
      "url": "https://mcp.notion.com/sse",
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    },
    "google-drive": {
      "command": "npx",
      "args": [
        "@piotr-agier/google-drive-mcp"
      ],
      "env": {
        "GOOGLE_DRIVE_CLIENT_ID": "${GDRIVE_CLIENT_ID}",
        "GOOGLE_DRIVE_CLIENT_SECRET": "${GDRIVE_CLIENT_SECRET}",
        "GOOGLE_DRIVE_REFRESH_TOKEN": "${GDRIVE_REFRESH_TOKEN}"
      }
    },
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_GITHUB_COMMAND_PACKAGE}",
        "${MCP_GITHUB_URL}"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "vercel-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_VERCEL_COMMAND_PACKAGE}",
        "${MCP_VERCEL_URL}"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "telegram-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_TELEGRAM_COMMAND_PACKAGE}"
      ],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_TOKEN}",
        "TELEGRAM_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_DEFAULT_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_SIMULATION_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}"
      }
    },
    "sentry-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_SENTRY_COMMAND_PACKAGE}"
      ],
      "env": {
        "SENTRY_ACCESS_TOKEN": "${SENTRY_ACCESS_TOKEN}"
      }
    },
    "playwright-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "perplexity-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_PERPLEXITY_COMMAND_PACKAGE}"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "obsidian-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_OBSIDIAN_COMMAND_PACKAGE}"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_BASE_URL": "${OBSIDIAN_BASE_URL}",
        "OBSIDIAN_VERIFY_SSL": "${OBSIDIAN_VERIFY_SSL}",
        "OBSIDIAN_ENABLE_CACHE": "${OBSIDIAN_ENABLE_CACHE}"
      }
    }
  },
  "inputs": []
}
