        "@iqai/mcp-telegram"
      ],
      "env": {
        "TELEGRAM_BOT_TOKEN": "8468786480:AAFytUe-qHOfhsagEwTwDxn0l5vSxQbKmzs",
        "TELEGRAM_CHAT_ID": "1281749368",
