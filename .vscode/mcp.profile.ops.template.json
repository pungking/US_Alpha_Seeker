{
  "servers": {
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_GITHUB_COMMAND_PACKAGE}",
        "${MCP_GITHUB_URL}"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "vercel-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_VERCEL_COMMAND_PACKAGE}",
        "${MCP_VERCEL_URL}"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "telegram-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_TELEGRAM_COMMAND_PACKAGE}"
      ],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_TOKEN}",
        "TELEGRAM_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_DEFAULT_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_SIMULATION_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}"
      }
    },
    "sentry-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_SENTRY_COMMAND_PACKAGE}"
      ],
      "env": {
        "SENTRY_ACCESS_TOKEN": "${SENTRY_ACCESS_TOKEN}"
      }
    }
  },
  "inputs": []
}
