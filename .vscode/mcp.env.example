MCP_VERCEL_COMMAND_PACKAGE=mcp-remote
MCP_VERCEL_URL=https://mcp.vercel.com
VERCEL_TOKEN=
MCP_TELEGRAM_COMMAND_PACKAGE=@iqai/mcp-telegram
