{
  "servers": {
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_GITHUB_COMMAND_PACKAGE}",
        "${MCP_GITHUB_URL}"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "vercel-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_VERCEL_COMMAND_PACKAGE}",
        "${MCP_VERCEL_URL}"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "telegram-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_TELEGRAM_COMMAND_PACKAGE}"
      ],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_TOKEN}",
        "TELEGRAM_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_DEFAULT_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}",
        "TELEGRAM_SIMULATION_CHAT_ID": "${TELEGRAM_SIMULATION_CHAT_ID}"
      }
    },
    "sentry-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_SENTRY_COMMAND_PACKAGE}"
      ],
      "env": {
        "SENTRY_ACCESS_TOKEN": "${SENTRY_ACCESS_TOKEN}"
      }
    },
    "playwright-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "grafana-mcp": {
      "command": "${MCP_GRAFANA_COMMAND}",
      "args": [
        "${MCP_GRAFANA_COMMAND_PACKAGE}",
        "--disable-write"
      ],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "pagerduty-mcp": {
      "command": "${MCP_PAGERDUTY_COMMAND}",
      "args": [
        "${MCP_PAGERDUTY_COMMAND_PACKAGE}"
      ],
      "env": {
        "PAGERDUTY_USER_API_KEY": "${PAGERDUTY_USER_API_KEY}",
        "PAGERDUTY_API_HOST": "${PAGERDUTY_API_HOST}"
      }
    },
    "cloudflare-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_CLOUDFLARE_COMMAND_PACKAGE}",
        "${MCP_CLOUDFLARE_URL}"
      ]
    },
    "obsidian-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_OBSIDIAN_COMMAND_PACKAGE}"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_BASE_URL": "${OBSIDIAN_BASE_URL}",
        "OBSIDIAN_VERIFY_SSL": "${OBSIDIAN_VERIFY_SSL}",
        "OBSIDIAN_ENABLE_CACHE": "${OBSIDIAN_ENABLE_CACHE}"
      }
    },
    "perplexity-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "${MCP_PERPLEXITY_COMMAND_PACKAGE}"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    }
  },
  "inputs": []
}
