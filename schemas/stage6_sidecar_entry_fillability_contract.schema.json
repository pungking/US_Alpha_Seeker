{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://us-alpha-seeker.local/schemas/stage6_sidecar_entry_fillability_contract.schema.json",
  "title": "Stage6 Sidecar Entry Fillability Contract",
  "type": "object",
  "required": ["schema_version", "generated_at", "candidates"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "decisionGate": {
      "type": "object",
      "properties": {
        "currentEntryMinRr": { "type": "number", "exclusiveMinimum": 0 },
        "currentEntryMaxAdaptiveDistancePct": { "type": "number", "minimum": 0 },
        "currentEntryMinTargetBufferPct": { "type": "number", "minimum": 0 },
        "zeroExecutableFormulaContract": {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "requiredRowFields": { "type": "array", "items": { "type": "string" } },
            "laneToBottleneck": { "type": "object", "additionalProperties": { "type": "string" } },
            "laneSpecificRowFields": {
              "type": "object",
              "additionalProperties": { "type": "array", "items": { "type": "string" } }
            },
            "evidenceRules": { "type": "object", "additionalProperties": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage6Candidate" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "nullableNumber": {
      "anyOf": [
        { "type": "number" },
        { "type": "null" }
      ]
    },
    "nullableString": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "nullableBoolean": {
      "anyOf": [
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "nullableStringArray": {
      "anyOf": [
        { "type": "array", "items": { "type": "string" } },
        { "type": "null" }
      ]
    },
    "stage6Candidate": {
      "type": "object",
      "required": [
        "symbol",
        "finalDecision",
        "decisionReason",
        "executionFeasibilityAtCurrent"
      ],
      "properties": {
        "symbol": { "type": "string", "minLength": 1 },
        "finalDecision": {
          "type": "string",
          "enum": ["EXECUTABLE_NOW", "WAIT_PRICE", "BLOCKED_RISK", "BLOCKED_EVENT"]
        },
        "decisionReason": { "type": "string", "minLength": 1 },
        "entryExecPrice": { "$ref": "#/$defs/nullableNumber" },
        "entryExecPriceShadow": { "$ref": "#/$defs/nullableNumber" },
        "targetPrice": { "$ref": "#/$defs/nullableNumber" },
        "targetMeanPrice": { "$ref": "#/$defs/nullableNumber" },
        "price": { "$ref": "#/$defs/nullableNumber" },
        "stopPrice": { "$ref": "#/$defs/nullableNumber" },
        "stopLoss": { "$ref": "#/$defs/nullableNumber" },
        "ictStopLoss": { "$ref": "#/$defs/nullableNumber" },
        "executionActionableVerdict": { "$ref": "#/$defs/nullableBoolean" },
        "rrAtCurrentPrice": { "$ref": "#/$defs/nullableNumber" },
        "entryDistancePct": { "$ref": "#/$defs/nullableNumber" },
        "entryDistancePctShadow": { "$ref": "#/$defs/nullableNumber" },
        "targetBufferFromCurrentPct": { "$ref": "#/$defs/nullableNumber" },
        "executionFeasibilityAtCurrent": {
          "type": "string",
          "enum": ["PASS", "BLOCKED", "UNKNOWN"]
        },
        "executionFeasibilityAtCurrentVerdict": { "$ref": "#/$defs/nullableString" },
        "executionFeasibilityAtCurrentReason": { "$ref": "#/$defs/nullableString" },
        "executionFeasibilityAtCurrentReasons": {
          "anyOf": [
            { "type": "array", "items": { "type": "string" } },
            { "type": "null" }
          ]
        },
        "executionFeasibilityAtCurrentRr": { "$ref": "#/$defs/nullableNumber" },
        "executionFeasibilityAtCurrentDistancePct": { "$ref": "#/$defs/nullableNumber" },
        "executionFeasibilityAtCurrentMinRr": { "$ref": "#/$defs/nullableNumber" },
